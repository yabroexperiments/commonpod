{
  "name": "commonpod",
  "version": "0.1.0",
  "description": "Provider-agnostic print-on-demand integration (Printful first; Asia-region providers planned). Shared across the yabroexperiments portfolio.",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "INTEGRATION_GUIDE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "print-on-demand",
    "pod",
    "printful",
    "fulfillment"
  ],
  "author": "yabroexperiments",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yabroexperiments/commonpod.git"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
